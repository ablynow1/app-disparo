generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------
// MÓDULO CORE: CONTATOS E MENSAGERIA TIMELINE
// ---------------------------------------------------------

model Contact {
  id        String   @id @default(cuid())
  remoteJid String   @unique
  pushName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  ConversationLog[]
}

model ConversationLog {
  id        String    @id @default(cuid())
  text      String    @db.Text
  direction Direction
  createdAt DateTime  @default(now())

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

enum Direction {
  INBOUND
  OUTBOUND
}

// ---------------------------------------------------------
// MÓDULO 1: ROTEAMENTO MULTI-INSTÂNCIA E GATILHOS
// ---------------------------------------------------------

model Instance {
  id          String   @id @default(cuid())
  name        String
  remoteJid   String?  @unique
  status      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relação N:M via tabela de junção explícita (Postgres)
  triggerRules TriggerRuleInstance[]
}

model TriggerRule {
  id              String          @id @default(cuid())
  name            String
  eventType       EventType
  routingStrategy RoutingStrategy @default(ROUND_ROBIN)
  delayMinutes    Int             @default(10)
  active          Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agentId String?
  agent   AIAgent? @relation(fields: [agentId], references: [id], onDelete: NoAction)

  // Relação N:M via tabela de junção explícita (Postgres)
  instances TriggerRuleInstance[]

  @@index([eventType, active])
  @@index([agentId])
}

// Tabela de junção N:M (TriggerRule <-> Instance)
model TriggerRuleInstance {
  triggerRuleId String
  instanceId    String

  triggerRule TriggerRule @relation(fields: [triggerRuleId], references: [id], onDelete: Cascade)
  instance    Instance    @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@id([triggerRuleId, instanceId])
}

enum RoutingStrategy {
  ROUND_ROBIN
  RANDOM
}

enum EventType {
  ABANDONED_CART
  PIX_PENDING
  ORDER_PAID
  ORDER_CANCELED
}

// ---------------------------------------------------------
// MÓDULO 2: INTEGRAÇÕES E-COMMERCE & PEDIDOS IDEMPOTENTES
// ---------------------------------------------------------

model Integration {
  id          String    @id @default(cuid())
  provider    Provider
  webhookUrl  String?
  credentials Json?
  active      Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

enum Provider {
  SHOPIFY
  YAMPI
  APPMAX
  HOTMART
  KIWIFY
}

model Order {
  id              String      @id @default(cuid())
  externalOrderId String
  customerName    String
  customerPhone   String
  amount          Float
  status          OrderStatus
  payload         Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, externalOrderId])
  @@index([externalOrderId])
  @@index([status])
  @@index([customerPhone])
}

enum OrderStatus {
  PENDING
  PAID
  CANCELED
  FAILED_TO_SEND
}

// ---------------------------------------------------------
// MÓDULO 3: CÉREBRO DE INTELIGÊNCIA ARTIFICIAL (BASE RAG)
// ---------------------------------------------------------

model AIAgent {
  id           String     @id @default(cuid())
  name         String
  systemPrompt String     @db.Text
  temperature  Float      @default(0.7)
  provider     AIProvider @default(OPENAI)
  isActive     Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  knowledgeBases AIKnowledgeBase[]
  triggerRules   TriggerRule[]
}

enum AIProvider {
  OPENAI
  ANTHROPIC
  GOOGLE_VERTEX
}

model AIKnowledgeBase {
  id      String @id @default(cuid())
  title   String
  content String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agentId String
  agent   AIAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}
